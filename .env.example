# API Keys & Configuration Example
# Copy this file to .env and fill in your actual keys

# --- APP FRONTEND (Vite) ---
# Aviationstack API (Flight data)
VITE_AVIATIONSTACK_KEY=your_aviationstack_key_here

# --- SUPORT SCRIPTS ---
# SerpApi (Search results if needed)
SERPAPI_KEY=your_serpapi_key_here
# Cloudinary (Image management if needed)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret